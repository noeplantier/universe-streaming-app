  "implementation_guidelines": {
    "tech_stack": {
      "framework": "React Native (Expo SDK 54)",
      "navigation": "Expo Router",
      "styling": "StyleSheet.create (NO TAILWIND)",
      "animations": "react-native-reanimated",
      "gestures": "react-native-gesture-handler"
    },
    "best_practices": [
      "Use SafeAreaView for all screens",
      "Implement Expo BlurView for glass effects",
      "Use FlatList for all feeds with windowSize optimization",
      "Wrap text in Text components with predefined styles",
      "Use Pressable for interactions with ripple config",
      "All interactive elements MUST have testID prop"
    ]
  },
  "universal_guidelines": [
    "Always use Dark Mode. There is no Light Mode in space.",
    "Borders should be subtle and colored (Purple/Violet), not grey.",
    "Use high contrast text (White on Black).",
    "Avoid system default blue. Use Nebula Violet for links/actions.",
    "Images should have a subtle overlay gradient if text is placed on top.",
    "Scroll views should have `showsVerticalScrollIndicator={false}` for immersion.",
    "Bottom Tab Bar should have a glass effect (BlurView) and float above content."
  ]
}